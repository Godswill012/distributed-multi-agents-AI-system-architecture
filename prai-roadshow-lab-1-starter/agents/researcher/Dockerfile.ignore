FROM python:3.12-slim

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Set working directory FIRST
WORKDIR /app

# Copy everything into /app
COPY . /app

# Environment setup
ENV PYTHONUNBUFFERED=1
ENV VIRTUAL_ENV=/opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Install dependencies
RUN uv venv /opt/venv && \
    . /opt/venv/bin/activate && \
    if [ -f pyproject.toml ]; then \
        uv sync --active; \
    elif [ -f requirements.txt ]; then \
        uv pip install -U -r requirements.txt; \
    fi

# Final check: Verify the file exists in the image during build
RUN ls -l /app/adk_app.py

# Explicit absolute path to the script
# Use the python binary from the venv
ENTRYPOINT ["/opt/venv/bin/python"]

# Pass the script and arguments (removed the extra "python" string)
CMD ["adk_app.py"]
# Run ADK API Server
#CMD ["adk_app.py"]
