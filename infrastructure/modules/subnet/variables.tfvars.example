project = "your-gcp-project-id"
region  = "us-central1"
name    = "dev-subnet"
# network: set to module.vpc.self_link in your environment main.tf
# network = module.vpc.self_link
ip_cidr_range = "10.10.0.0/20"
private_ip_google_access = false

# secondary_ip_ranges is a list of objects used by GKE IP aliasing
secondary_ip_ranges = [
  { range_name = "pods-range", ip_cidr_range = "10.10.8.0/21" },
  { range_name = "services-range", ip_cidr_range = "10.10.16.0/24" },
]
