/*
Example Terraform to create a GCS bucket for Terraform remote state.

Use this only as a reference or starting point.
For the real backend bootstrap in this repo, use the dedicated
infrastructure/backend root instead.

Why this exists:
- shows how to create a GCS bucket for remote state
- enables object versioning for state recovery
- enforces secure bucket settings

After creating the bucket, configure your environment backend with:

terraform {
  backend "gcs" {}
}

and initialize using:

terraform init -migrate-state \
  -backend-config="bucket=YOUR_BACKEND_BUCKET" \
  -backend-config="prefix=gke/dev"
*/

resource "google_storage_bucket" "tf_state" {
  name                        = var.backend_bucket_name
  project                     = var.project_id
  location                    = var.region
  uniform_bucket_level_access = true
  public_access_prevention    = "enforced"
  force_destroy               = false

  versioning {
    enabled = true
  }
}
